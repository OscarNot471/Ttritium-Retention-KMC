def guardar_animacion_gif(
    trayectoria,
    tiempos,
    red,
    Lx,
    Ly,
    guardar_cada,
    carpeta_resultados,
    fps=15,
    max_frames=300
):

    ruta_animacion = os.path.join(
        carpeta_resultados,
        "animacion_difusion.gif"
    )

    print("Preparando animación...")

    n_frames_total = len(trayectoria)

    if n_frames_total == 0:
        print("No hay frames guardados para la animación.")
        return

    # Si hay demasiados frames, seleccionamos solo algunos
    if n_frames_total > max_frames:
        indices_frames = np.linspace(
            0,
            n_frames_total - 1,
            max_frames,
            dtype=int
        )
    else:
        indices_frames = np.arange(n_frames_total)

    frames_gif = []

    # Coordenadas fijas de defectos
    x_vac, y_vac = np.where(red == 1)
    x_dis, y_dis = np.where(red == 2)
    x_gb, y_gb = np.where(red == 3)
    x_cav, y_cav = np.where(red == 4)

    for contador, frame in enumerate(indices_frames):

        if contador % 25 == 0:
            print(f"Frame animación: {contador}/{len(indices_frames)}")

        fig, ax = plt.subplots(figsize=(7, 6))
        fig.subplots_adjust(right=0.78)

        # Fondo
        fondo = np.zeros((Lx, Ly))

        ax.imshow(
            fondo.T,
            origin="lower",
            extent=[0, Lx, 0, Ly],
            cmap="Blues",
            vmin=-1,
            vmax=1
        )

        # Defectos
        ax.scatter(
            x_vac + 0.5,
            y_vac + 0.5,
            marker="s",
            s=8,
            c="black",
            label="Vacantes"
        )

        ax.scatter(
            x_dis + 0.5,
            y_dis + 0.5,
            marker="s",
            s=8,
            c="red",
            label="Dislocaciones"
        )

        ax.scatter(
            x_gb + 0.5,
            y_gb + 0.5,
            marker="s",
            s=8,
            c="orange",
            label="Bordes de grano"
        )

        ax.scatter(
            x_cav + 0.5,
            y_cav + 0.5,
            marker="s",
            s=12,
            c="purple",
            label="Cavidades"
        )

        # Partículas
        posiciones = trayectoria[frame]

        libres = []
        atrapadas = []

        for x, y in posiciones:
            if red[x, y] == 0:
                libres.append([x + 0.5, y + 0.5])
            else:
                atrapadas.append([x + 0.5, y + 0.5])

        if len(atrapadas) > 0:
            atrapadas = np.array(atrapadas)

            ax.scatter(
                atrapadas[:, 0],
                atrapadas[:, 1],
                marker="s",
                s=22,
                c="yellow",
                edgecolors="black",
                linewidths=0.4,
                label="Tritio atrapado"
            )

        if len(libres) > 0:
            libres = np.array(libres)

            ax.scatter(
                libres[:, 0],
                libres[:, 1],
                marker="s",
                s=6,
                c="cyan",
                edgecolors="white",
                linewidths=0.2,
                alpha=0.75,
                label="Tritio libre"
            )

        # Formato
        ax.set_xlim(0, Lx)
        ax.set_ylim(0, Ly)
        ax.set_xlabel("x")
        ax.set_ylabel("y")
        ax.set_aspect("equal")

        ax.legend(loc="upper left", bbox_to_anchor=(1.02, 1.0))

        ax.set_title(
            f"Difusión de tritio - t = {tiempos[frame] * 1e9:.3f} ns"
        )

        # Convertir figura a imagen
        fig.canvas.draw()

        imagen = np.asarray(fig.canvas.buffer_rgba())
        imagen_pil = Image.fromarray(imagen)

        frames_gif.append(imagen_pil.convert("P"))

        plt.close(fig)

    print("Guardando animación en:", ruta_animacion)

    duracion_ms = int(1000 / fps)

    frames_gif[0].save(
        ruta_animacion,
        save_all=True,
        append_images=frames_gif[1:],
        duration=duracion_ms,
        loop=0
    )

    print("Animación guardada:", ruta_animacion)




def guardar_capturas_animacion(
    trayectoria,
