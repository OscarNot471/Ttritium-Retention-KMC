    os.makedirs(carpeta_capturas, exist_ok=True)

    if len(trayectoria) == 0:
        print("No hay frames guardados para capturas.")
        return

    n_frames = len(trayectoria)

    # Capturas: inicio, 1/3, 2/3 y final
    indices_capturas = [
        0,
        int((n_frames - 1) / 3),
        int(2 * (n_frames - 1) / 3),
